<# NeurIPS paper template for NanoResearch #>
<# Uses custom Jinja2 delimiters: <% %> for blocks, << >> for variables, <# #> for comments #>
\documentclass{article}

%% ---- NeurIPS 2025 Style ----
\usepackage[final,main]{neurips_2025}

%% ---- Standard Packages ----
\usepackage[utf8]{inputenc}
\usepackage[T1]{fontenc}
\usepackage{amsmath}
\usepackage{amssymb}
\usepackage{graphicx}
\usepackage{hyperref}
%% natbib is auto-loaded by neurips_2025.sty
\usepackage{booktabs}
\usepackage{xcolor}
\usepackage{float}
\usepackage[section]{placeins}
\usepackage{multirow}

\title{<< title >>}
\author{<%- for author in authors %>
<< author >><% if not loop.last %> \and <% endif %>
<%- endfor %>}

\begin{document}

\maketitle

%% ---- Abstract ----
\begin{abstract}
<< abstract >>
\end{abstract}

%% ---- Sections ----
<% for section in sections %>
\section{<< section.heading >>}\label{<< section.label >>}

<< section.content >>

<% for subsection in section.subsections %>
\subsection{<< subsection.heading >>}\label{<< subsection.label >>}

<< subsection.content >>

<% endfor %>
<% endfor %>

%% ---- Figures ----
<% for figure in figures %>
\begin{figure}[htbp]
    \centering
    \includegraphics[width=<< figure.width >>\textwidth]{<< figure.filename >>}
    \caption{<< figure.caption >>}
    \label{fig:<< figure.figure_id >>}
\end{figure}

<% endfor %>

%% ---- References ----
\bibliographystyle{plainnat}
\bibliography{references}

\end{document}
